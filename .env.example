# Server port
PORT=8080

# Storage driver: sqlite (default, local) | dynamodb (cloud, pending implementation)
DB_DRIVER=sqlite

# SQLite database file path (DB_DRIVER=sqlite)
DATABASE_PATH=quiz.db

# DynamoDB table name (DB_DRIVER=dynamodb)
DYNAMODB_TABLE=

# Gin mode: debug | release | test
GIN_MODE=debug

# Comma-separated list of allowed CORS origins (empty = allow all, dev only)
ALLOWED_ORIGINS=
