# Server port
PORT=8080

# Storage driver: sqlite (default, local) | dynamodb (cloud/serverless)
DB_DRIVER=sqlite

# SQLite database file path (DB_DRIVER=sqlite)
DATABASE_PATH=quiz.db

# DynamoDB table name (DB_DRIVER=dynamodb)
DYNAMODB_TABLE=

# DynamoDB Local endpoint override, e.g. http://localhost:8000 (local dev only;
# also auto-creates the table and applies dummy region/credentials)
DYNAMODB_ENDPOINT=

# AWS region (DB_DRIVER=dynamodb against real AWS)
AWS_REGION=us-east-1

# Sync the embedded question bank into the store at startup (true by default).
# Set to false in Lambda: seeding runs at deploy time via the CDK seeder.
SEED_ON_START=true

# Gin mode: debug | release | test
GIN_MODE=debug

# Comma-separated list of allowed CORS origins. Empty falls back to allow-all
# in debug mode only; required when GIN_MODE=release (server refuses to start
# without it).
ALLOWED_ORIGINS=

# Comma-separated usernames allowed to call the admin endpoints
# (GET /api/admin/metrics). Empty = nobody (the endpoints answer 404).
ADMIN_USERNAMES=

# Max guest accounts (POST /api/guest) per Colombian day before the endpoint
# answers 503 — cost circuit breaker against abuse. Default: 2000.
GUEST_DAILY_CAP=
